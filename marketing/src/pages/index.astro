---
import Layout from '../layouts/Layout.astro';
import { Shield, Users, Clock, BrainCircuit, Zap, ArrowRight, Lock } from 'lucide-react';
---

<Layout title="Nexus HRM | The Enterprise Workforce OS">
	<main class="bg-[#F8FAFC]">
		<!-- Global Navigation (Zoho Inspired) -->
		<nav class="fixed top-0 left-0 right-0 z-[100] bg-white/80 backdrop-blur-md border-b border-slate-200 px-6 py-4">
			<div class="max-w-7xl mx-auto flex justify-between items-center">
				<div class="flex items-center gap-3">
					<div class="w-8 h-8 bg-indigo-600 rounded-lg flex items-center justify-center text-white">
						<Shield size={18} />
					</div>
					<span class="text-xl font-bold tracking-tight text-slate-900">Nexus<span class="text-indigo-600">HRM</span></span>
				</div>
				<div class="hidden md:flex items-center gap-8">
					<a href="#features" class="text-sm font-semibold text-slate-600 hover:text-indigo-600 transition-colors">Features</a>
					<a href="#solutions" class="text-sm font-semibold text-slate-600 hover:text-indigo-600 transition-colors">Solutions</a>
					<a href="#security" class="text-sm font-semibold text-slate-600 hover:text-indigo-600 transition-colors">Security</a>
					<a href="/portal" class="px-5 py-2.5 bg-indigo-600 text-white rounded-lg text-sm font-bold hover:bg-indigo-700 transition-all shadow-lg shadow-indigo-200">
						Launch Demo App
					</a>
				</div>
			</div>
		</nav>

		<!-- Hero Section -->
		<section class="relative pt-40 pb-32 px-6 overflow-hidden bg-gradient-to-b from-slate-50 to-white">
			<div class="max-w-7xl mx-auto text-center relative z-10">
				<div class="inline-flex items-center gap-2 px-4 py-2 rounded-full bg-indigo-50 border border-indigo-100 mb-8">
					<span class="text-[10px] font-bold uppercase tracking-widest text-indigo-600">The Modern Workforce Blueprint</span>
				</div>
				
				<h1 class="text-5xl md:text-7xl font-extrabold tracking-tight text-slate-900 mb-8 leading-[1.1]">
					Agile HR Management <br/>
					for the <span class="text-indigo-600">Modern Enterprise.</span>
				</h1>

				<p class="max-w-3xl mx-auto text-xl text-slate-600 font-medium leading-relaxed mb-12">
					Nexus HRM simplifies your employee lifecycle. From strategic onboarding to precise payroll and performance analytics, manage your entire workforce through a singular, intelligent command center.
				</p>

				<div class="flex flex-col sm:flex-row items-center justify-center gap-4">
					<a href="/portal" class="w-full sm:w-auto px-8 py-4 bg-indigo-600 text-white rounded-xl font-bold flex items-center justify-center gap-3 hover:bg-indigo-700 transition-all shadow-xl">
						Explore the Demo Hub <ArrowRight size={18} />
					</a>
					<a href="#features" class="w-full sm:w-auto px-8 py-4 bg-white border border-slate-200 text-slate-700 rounded-xl font-bold hover:bg-slate-50 transition-all">
						Core Capabilities
					</a>
				</div>
			</div>

			<!-- Product Preview -->
			<div class="max-w-6xl mx-auto mt-24 relative px-4">
				<div class="rounded-[2rem] overflow-hidden border border-slate-200 shadow-[0_40px_100px_-20px_rgba(0,0,0,0.1)] bg-white p-2">
					<img 
						src="/nexus-preview-hero.png" 
						alt="Nexus Dashboard Preview" 
						class="w-full h-auto rounded-[1.5rem]"
					/>
				</div>
			</div>
		</section>

		<!-- Features Grid (Zoho People Inspired) -->
		<section id="features" class="py-32 px-6 bg-white">
			<div class="max-w-7xl mx-auto">
				<div class="text-center mb-24">
					<h2 class="text-xs font-bold text-indigo-600 uppercase tracking-[0.3em] mb-4">Powerful Features</h2>
					<h3 class="text-4xl md:text-5xl font-black text-slate-900 tracking-tight">Everything you need to <br/> scale your human capital.</h3>
				</div>

				<div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
					<!-- Core HR -->
					<div class="p-10 rounded-[2.5rem] bg-slate-50 border border-slate-100 hover:bg-white hover:shadow-2xl hover:shadow-indigo-500/5 transition-all group">
						<div class="w-14 h-14 bg-blue-100 rounded-2xl flex items-center justify-center text-blue-600 mb-8 group-hover:scale-110 transition-transform">
							<Users size={28} />
						</div>
						<h4 class="text-2xl font-bold text-slate-900 mb-4">Workforce Database</h4>
						<p class="text-slate-600 leading-relaxed font-medium">Keep your employee records organized and accessible. Manage documentation, personal info, and organizational hierarchy in one place.</p>
					</div>

					<!-- Time & Attendance -->
					<div class="p-10 rounded-[2.5rem] bg-slate-50 border border-slate-100 hover:bg-white hover:shadow-2xl hover:shadow-indigo-500/5 transition-all group">
						<div class="w-14 h-14 bg-amber-100 rounded-2xl flex items-center justify-center text-amber-600 mb-8 group-hover:scale-110 transition-transform">
							<Clock size={28} />
						</div>
						<h4 class="text-2xl font-bold text-slate-900 mb-4">Time & Attendance</h4>
						<p class="text-slate-600 leading-relaxed font-medium">Hardware-agnostic tracking with biometric integration, geo-fencing, and real-time presence verification for every staff member.</p>
					</div>

					<!-- Performance -->
					<div class="p-10 rounded-[2.5rem] bg-slate-50 border border-slate-100 hover:bg-white hover:shadow-2xl hover:shadow-indigo-500/5 transition-all group">
						<div class="w-14 h-14 bg-emerald-100 rounded-2xl flex items-center justify-center text-emerald-600 mb-8 group-hover:scale-110 transition-transform">
							<BrainCircuit size={28} />
						</div>
						<h4 class="text-2xl font-bold text-slate-900 mb-4">Agile Performance</h4>
						<p class="text-slate-600 leading-relaxed font-medium">Continuous feedback cycles, KRA tracking, and 360-degree appraisals designed to foster employee growth and strategic alignment.</p>
					</div>

					<!-- Payroll -->
					<div class="p-10 rounded-[2.5rem] bg-slate-50 border border-slate-100 hover:bg-white hover:shadow-2xl hover:shadow-indigo-500/5 transition-all group">
						<div class="w-14 h-14 bg-rose-100 rounded-2xl flex items-center justify-center text-rose-600 mb-8 group-hover:scale-110 transition-transform">
							<Zap size={28} />
						</div>
						<h4 class="text-2xl font-bold text-slate-900 mb-4">Nuclear Payroll</h4>
						<p class="text-slate-600 leading-relaxed font-medium">Automated disbursements with built-in tax compliance. Process entire departmental payrolls with a single, verified click.</p>
					</div>

					<!-- Self Service -->
					<div class="p-10 rounded-[2.5rem] bg-slate-50 border border-slate-100 hover:bg-white hover:shadow-2xl hover:shadow-indigo-500/5 transition-all group">
						<div class="w-14 h-14 bg-indigo-100 rounded-2xl flex items-center justify-center text-indigo-600 mb-8 group-hover:scale-110 transition-transform">
							<Users size={28} />
						</div>
						<h4 class="text-2xl font-bold text-slate-900 mb-4">Employee Hub</h4>
						<p class="text-slate-600 leading-relaxed font-medium">Self-service portal for staff to request leave, view payslips, and manage their own professional growth pathways.</p>
					</div>

					<!-- Analytics -->
					<div class="p-10 rounded-[2.5rem] bg-slate-50 border border-slate-100 hover:bg-white hover:shadow-2xl hover:shadow-indigo-500/5 transition-all group">
						<div class="w-14 h-14 bg-slate-200 rounded-2xl flex items-center justify-center text-slate-700 mb-8 group-hover:scale-110 transition-transform">
							<BrainCircuit size={28} />
						</div>
						<h4 class="text-2xl font-bold text-slate-900 mb-4">Case Management</h4>
						<p class="text-slate-600 leading-relaxed font-medium">Structured HR help desk to resolve queries faster. Streamline communication between employees and the HR department.</p>
					</div>
				</div>
			</div>
		</section>

		<!-- Security Trust -->
		<section id="security" class="py-32 px-6 bg-slate-900 text-white">
			<div class="max-w-7xl mx-auto flex flex-col lg:flex-row items-center gap-20">
				<div class="lg:w-1/2">
					<h2 class="text-xs font-bold text-indigo-400 uppercase tracking-[0.4em] mb-6">Enterprise Grade</h2>
					<h3 class="text-5xl font-black tracking-tight mb-8">Data security is in <br/> our corporate DNA.</h3>
					<p class="text-lg text-slate-400 leading-relaxed mb-12 font-medium">
						Nexus HRM is built with multi-layered security protocols. Every organization is isolated within its own secure vault, ensuring zero data leakage and 99.9% availability.
					</p>
					<ul class="space-y-6">
						{['Bank-grade Encryption', 'Multi-tenant Data Isolation', 'SOC 2 & GDPR Compliance', 'Biometric SSO Integration'].map(item => (
							<li class="flex items-center gap-4 text-slate-300 font-bold">
								<div class="w-6 h-6 rounded-full bg-indigo-500/20 border border-indigo-500/30 flex items-center justify-center text-indigo-400">
									<Zap size={12} />
								</div>
								{item}
							</li>
						))}
					</ul>
				</div>
				<div class="lg:w-1/2">
					<div class="p-1 bg-white/5 border border-white/10 rounded-[3rem] overflow-hidden">
						<div class="bg-slate-950 p-12 rounded-[2.8rem]">
							<div class="flex items-center gap-2 mb-10">
								<div class="w-3 h-3 rounded-full bg-rose-500"></div>
								<div class="w-3 h-3 rounded-full bg-amber-500"></div>
								<div class="w-3 h-3 rounded-full bg-emerald-500"></div>
							</div>
							<div class="space-y-4 font-mono text-sm">
								<p class="text-indigo-400"># Initializing Security Subsystem...</p>
								<p class="text-slate-500">> Verifying HMAC Signature...</p>
								<p class="text-slate-500">> Encrypting Storage Tier [AES-256]</p>
								<p class="text-emerald-400">> SHIELD STATUS: OPERATIONAL</p>
							</div>
						</div>
					</div>
				</div>
			</div>
		</section>

		<!-- Footer -->
		<footer class="bg-white border-t border-slate-200 pt-20 pb-10 px-6">
			<div class="max-w-7xl mx-auto flex flex-col md:flex-row justify-between items-start gap-12 mb-20">
				<div class="max-w-sm">
					<div class="flex items-center gap-3 mb-6">
						<div class="w-8 h-8 bg-indigo-600 rounded-lg flex items-center justify-center text-white">
							<Shield size={18} />
						</div>
						<span class="text-xl font-bold tracking-tight text-slate-900">Nexus<span class="text-indigo-600">HRM</span></span>
					</div>
					<p class="text-slate-500 font-medium leading-relaxed">
						The next generation of human resource management. Empowering global teams with intelligent workforce orchestration.
					</p>
				</div>
				<div class="grid grid-cols-2 md:grid-cols-3 gap-16">
					<div>
						<h5 class="text-xs font-black uppercase tracking-widest text-slate-900 mb-6">Platform</h5>
						<ul class="space-y-4 text-sm font-semibold text-slate-500">
							<li><a href="#" class="hover:text-indigo-600 transition-colors">Features</a></li>
							<li><a href="#" class="hover:text-indigo-600 transition-colors">Pricing</a></li>
							<li><a href="#" class="hover:text-indigo-600 transition-colors">Integrations</a></li>
						</ul>
					</div>
					<div>
						<h5 class="text-xs font-black uppercase tracking-widest text-slate-900 mb-6">Security</h5>
						<ul class="space-y-4 text-sm font-semibold text-slate-500">
							<li><a href="#" class="hover:text-indigo-600 transition-colors">Compliance</a></li>
							<li><a href="#" class="hover:text-indigo-600 transition-colors">Data Privacy</a></li>
							<li><a href="#" class="hover:text-indigo-600 transition-colors">Trust Center</a></li>
						</ul>
					</div>
					<div>
						<h5 class="text-xs font-black uppercase tracking-widest text-slate-900 mb-6">Enterprise Hub</h5>
						<ul class="space-y-4 text-sm font-semibold text-slate-500">
							<li><a href="/portal" class="text-indigo-600 hover:underline">Demo Command Center</a></li>
							<li>
								<!-- Dev Account Access - Low Visibility -->
								<a href="/portal/login?access=dev" class="opacity-20 hover:opacity-100 flex items-center gap-2 group transition-opacity">
									<Lock size={12} class="group-hover:text-rose-500" />
									<span class="text-[10px]">Development Access</span>
								</a>
							</li>
						</ul>
					</div>
				</div>
			</div>
			<div class="max-w-7xl mx-auto border-t border-slate-100 pt-10 flex flex-col md:flex-row justify-between items-center gap-6">
				<p class="text-xs font-bold text-slate-400">© 2026 NEXUS CORE. ALL RIGHTS RESERVED.</p>
				<div class="flex gap-8 text-xs font-bold text-slate-400">
					<a href="#" class="hover:text-slate-600">Privacy Policy</a>
					<a href="#" class="hover:text-slate-600">Terms of Service</a>
				</div>
			</div>
		</footer>
	</main>
</Layout>

<style>
	.btn-primary {
		@apply bg-indigo-600 text-white rounded-xl font-bold flex items-center justify-center gap-3 hover:bg-indigo-700 transition-all shadow-xl shadow-indigo-200;
	}
	.btn-secondary {
		@apply bg-white border border-slate-200 text-slate-700 rounded-xl font-bold hover:bg-slate-50 transition-all;
	}
</style>

