---
import Layout from '../layouts/Layout.astro';
import { DemoLauncher } from '../components/DemoLauncher.tsx';
import { ReviewCortex } from '../components/ReviewCortex.tsx';
---

<Layout title="The Enterprise Operating System">
	<main>
		<!-- Hero Section -->
		<section class="relative min-h-screen flex items-center justify-center pt-20 pb-32 px-6 overflow-hidden">
			<!-- Background Visuals -->
			<div class="absolute inset-0 z-0">
				<div class="absolute top-1/4 left-1/4 w-[500px] h-[500px] bg-nexus-blue-600/10 blur-[120px] rounded-full animate-pulse-slow"></div>
				<div class="absolute bottom-1/4 right-1/4 w-[500px] h-[500px] bg-emerald-500/10 blur-[120px] rounded-full animate-pulse-slow"></div>
			</div>

			<div class="max-w-7xl mx-auto relative z-10 text-center">
				<div class="inline-flex items-center gap-2 px-4 py-2 rounded-full bg-white/5 border border-white/10 mb-8 animate-fade-in-up">
					<div class="w-2 h-2 rounded-full bg-nexus-blue-500 animate-pulse"></div>
					<span class="text-[10px] font-black uppercase tracking-[0.3em] text-slate-400">Nexus Platform Core v4.1.6</span>
				</div>
				
				<h1 class="text-6xl md:text-9xl font-black tracking-tighter leading-[0.85] mb-12 uppercase italic animate-fade-in-up">
					The Operating <br/>
					System for <br/>
					<span class="text-nexus-blue-500">Human Potential.</span>
				</h1>

				<p class="max-w-2xl mx-auto text-xl text-slate-400 font-medium leading-relaxed mb-16 animate-fade-in-up" style="animation-delay: 0.1s">
					Nexus redefines human resource management with recursive intelligence. Transition from fragmented spreadsheets to a singular, unified enterprise brain.
				</p>

				<div class="flex flex-col sm:flex-row items-center justify-center gap-6 animate-fade-in-up" style="animation-delay: 0.2s">
					<a href="#how-it-works" class="btn-primary w-full sm:w-auto text-center">
						Explore Infrastructure
					</a>
					<a href="#demo-hub" class="btn-secondary w-full sm:w-auto text-center">
						Zero-Password Demo
					</a>
				</div>
			</div>
		</section>

		<!-- Demo Hub Section -->
		<section id="demo-hub" class="py-32 px-6 relative bg-nexus-slate-950">
			<div class="max-w-7xl mx-auto">
				<div class="text-center mb-24">
					<h2 class="text-5xl md:text-7xl font-black uppercase italic tracking-tighter mb-8">One-Click Entry.</h2>
					<p class="text-lg text-slate-400 font-medium">Select a role to instantly simulate the Nexus experience. No credentials required.</p>
				</div>
				<DemoLauncher client:load />
			</div>
		</section>

		<!-- Capabilities Grid -->
		<section id="how-it-works" class="py-32 px-6 bg-white text-nexus-slate-950 rounded-[4rem] mx-4 my-8">
			<div class="max-w-7xl mx-auto">
				<div class="flex flex-col lg:flex-row justify-between items-end gap-12 mb-24">
					<div class="max-w-2xl">
						<h2 class="text-5xl md:text-7xl font-black uppercase italic tracking-tighter mb-8 leading-none">High Impact <br/> Core Modules</h2>
						<p class="text-lg text-slate-500 font-medium">Nexus focuses on high-impact operational zones, automating the complex and securing the essential for modern enterprises.</p>
					</div>
					<div class="hidden lg:block pb-4">
						<span class="text-xs font-black uppercase tracking-[0.4em] text-nexus-blue-600">Enterprise Ready</span>
					</div>
				</div>

				<div class="grid grid-cols-1 md:grid-cols-3 gap-12">
					<div class="p-12 bg-slate-50 rounded-[3rem] border border-slate-100 hover:shadow-2xl transition-all group">
						<div class="w-16 h-16 bg-nexus-blue-600 rounded-2xl flex items-center justify-center text-white mb-10 group-hover:scale-110 transition-transform">
							<svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M11 15h2a2 2 0 1 0 0-4h-3c-.6 0-1.1.4-1.4 1"/><path d="M7 21h10"/><path d="M12 3v18"/><path d="M3 7h2c2 0 5-1 7-2 2 1 5 2 7 2h2"/><path d="M3 7v10c0 1.1.9 2 2 2h2"/><path d="M17 19h2c1.1 0 2-.9 2-2V7"/></svg>
						</div>
						<h3 class="text-3xl font-black uppercase italic mb-6">Nuclear Payroll</h3>
						<p class="text-slate-500 font-medium leading-relaxed mb-8">Instant disbursement with 0.001% margin for error. Compliant with 40+ global tax regions automatically.</p>
						<div class="h-1 w-12 bg-nexus-blue-600 rounded-full"></div>
					</div>

					<div class="p-12 bg-slate-50 rounded-[3rem] border border-slate-100 hover:shadow-2xl transition-all group">
						<div class="w-16 h-16 bg-emerald-500 rounded-2xl flex items-center justify-center text-white mb-10 group-hover:scale-110 transition-transform">
							<svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M12 2c5.523 0 10 4.477 10 10s-4.477 10-10 10S2 17.523 2 12 6.477 2 12 2z"/><path d="M12 18v-6"/><path d="M12 8h.01"/></svg>
						</div>
						<h3 class="text-3xl font-black uppercase italic mb-6">Biometric Presence</h3>
						<p class="text-slate-500 font-medium leading-relaxed mb-8">Hardware-agnostic staff tracking. Real-time presence verification with anti-spoofing intelligence.</p>
						<div class="h-1 w-12 bg-emerald-500 rounded-full"></div>
					</div>

					<div class="p-12 bg-slate-50 rounded-[3rem] border border-slate-100 hover:shadow-2xl transition-all group">
						<div class="w-16 h-16 bg-nexus-slate-900 rounded-2xl flex items-center justify-center text-white mb-10 group-hover:scale-110 transition-transform">
							<svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M4.5 16.5c-1.5 1.26-2 5-2 5s3.74-.5 5-2c.71-.84.7-2.13-.09-2.91a2.18 2.18 0 0 0-2.91-.09z"/><path d="m12 15-3-3a22 22 0 0 1 2-3.95A12.88 12.88 0 0 1 22 2c0 2.72-.78 7.5-6 11a22.35 22.35 0 0 1-4 2z"/><path d="M9 12H4s.55-3.03 2-5c1.62-2.2 5-3 5-3"/><path d="M12 15v5s3.03-.55 5-2c2.2-1.62 3-5 3-5"/></svg>
						</div>
						<h3 class="text-3xl font-black uppercase italic mb-6">Cortex AI</h3>
						<p class="text-slate-500 font-medium leading-relaxed mb-8">Recursive employee appraisals. AI-driven talent growth maps and automated promotion triggers.</p>
						<div class="h-1 w-12 bg-nexus-slate-900 rounded-full"></div>
					</div>
				</div>
			</div>
		</section>

		<!-- Review Engine Exhibit -->
		<section class="py-32 px-6 bg-nexus-slate-950 overflow-hidden">
			<div class="max-w-5xl mx-auto">
				<div class="text-center mb-16">
					<h2 class="text-xs font-black uppercase tracking-[0.4em] text-nexus-blue-500 mb-4">Enterprise Resolution</h2>
					<p class="text-slate-400 font-medium">Strategic validation from the world's most aggressive teams.</p>
				</div>
				<ReviewCortex client:load />
			</div>
		</section>

		<!-- Security & Infrastructure Exhibit -->
		<section id="security" class="py-32 px-6">
			<div class="max-w-7xl mx-auto flex flex-col lg:flex-row items-center gap-20">
				<div class="lg:w-1/2">
					<div class="inline-flex items-center gap-2 px-4 py-2 rounded-full bg-nexus-blue-600/10 border border-nexus-blue-600/20 mb-8">
						<Shield className="w-4 h-4 text-nexus-blue-500" />
						<span class="text-[10px] font-black uppercase tracking-[0.3em] text-nexus-blue-500">Security Shell 1.0</span>
					</div>
					<h2 class="text-5xl md:text-7xl font-black uppercase italic tracking-tighter mb-8 leading-none">Enterprise <br/> Hardened.</h2>
					<p class="text-lg text-slate-400 font-medium leading-relaxed mb-12">
						Nexus is built on a defensive architecture. Every byte of tenant data is isolated within an encrypted vault, guarded by biometric-first identity protocols.
					</p>
					
					<div class="grid grid-cols-2 gap-8">
						<div>
							<h4 class="text-2xl font-black italic uppercase mb-2">ISO 27001</h4>
							<p class="text-sm text-slate-500 font-bold">Gold Standard Certification</p>
						</div>
						<div>
							<h4 class="text-2xl font-black italic uppercase mb-2">SOC 2 TYPE II</h4>
							<p class="text-sm text-slate-500 font-bold">Continuous Compliance</p>
						</div>
					</div>
				</div>
				<div class="lg:w-1/2 relative">
					<div class="glass-card p-4">
						<div class="bg-nexus-slate-950 rounded-[2rem] overflow-hidden border border-white/5 shadow-2xl">
							<div class="p-8 border-b border-white/5 flex items-center justify-between">
								<div class="flex gap-2">
									<div class="w-2 h-2 rounded-full bg-rose-500"></div>
									<div class="w-2 h-2 rounded-full bg-amber-500"></div>
									<div class="w-2 h-2 rounded-full bg-emerald-500"></div>
								</div>
								<span class="text-[10px] font-black uppercase tracking-[0.2em] text-slate-600 italic">DEFENSIVE_PROTOCOL.CORE</span>
							</div>
							<div class="p-12 font-mono text-sm space-y-4">
								<p class="text-emerald-500">>> INITIALIZING_ENCRYPTION_VAULT...</p>
								<p class="text-slate-400">>> AUTHENTICATING TENANT: ACME_GHANA_DEMO_001</p>
								<p class="text-slate-400">>> ROTATING QUANTUM_KEYS [SHA-512]</p>
								<p class="text-nexus-blue-500">>> SYSTEM_STATUS: OPERATIONAL [SHIELD_ACTIVE]</p>
							</div>
						</div>
					</div>
				</div>
			</div>
		</section>

		<!-- Pricing / DM for Quote -->
		<section id="pricing" class="py-32 px-6">
			<div class="max-w-4xl mx-auto glass-card p-20 text-center relative overflow-hidden">
				<div class="absolute -top-20 -right-20 w-64 h-64 bg-nexus-blue-600/10 blur-[80px] rounded-full"></div>
				<h2 class="text-6xl md:text-8xl font-black uppercase italic tracking-tighter mb-8">Strategic <br/> Investment</h2>
				<p class="text-xl text-slate-400 font-medium mb-16">
					Nexus is an enterprise-scale commitment. We provide custom infrastructure calibrated to your organization size and geographic complexity.
				</p>
				<a href="mailto:sales@nexus.com?subject=Strategic Query" class="btn-primary px-16 py-6 text-lg tracking-widest uppercase">
					Request Strategic Quote
				</a>
				<p class="mt-8 text-xs font-black text-slate-600 uppercase tracking-widest">Pricing defined by resolution capacity</p>
			</div>
		</section>
	</main>
</Layout>
