---
import '../styles/global.css';

interface Props {
	title: string;
	description?: string;
}

const { title, description = "Nexus HRM - The Operating System for Human Potential. Enterprise-grade HR management for modern teams." } = Astro.props;
---

<!doctype html>
<html lang="en">
	<head>
		<meta charset="UTF-8" />
		<meta name="description" content={description} />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<meta name="generator" content={Astro.generator} />
		<title>{title} | Nexus HRM Platform</title>
	</head>
	<body class="bg-nexus-slate-950 overflow-x-hidden">
		<!-- Global Navigation -->
		<nav class="fixed top-0 left-0 w-full z-50 px-6 py-4">
			<div class="max-w-7xl mx-auto flex items-center justify-between px-8 py-4 glass-card">
				<div class="flex items-center gap-3">
					<div class="w-10 h-10 bg-nexus-blue-600 rounded-xl flex items-center justify-center text-white shadow-lg shadow-nexus-blue-600/30">
						<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10"/></svg>
					</div>
					<span class="text-xl font-black italic tracking-tighter uppercase">Nexus</span>
				</div>

				<div class="hidden md:flex items-center gap-10">
					<a href="/" class="text-sm font-bold text-slate-400 hover:text-white transition-colors">Home</a>
					<a href="#how-it-works" class="text-sm font-bold text-slate-400 hover:text-white transition-colors">How it works</a>
					<a href="#pricing" class="text-sm font-bold text-slate-400 hover:text-white transition-colors">Pricing</a>
					<a href="#security" class="text-sm font-bold text-slate-400 hover:text-white transition-colors">Security</a>
				</div>

				<div class="flex items-center gap-4">
					<button class="btn-primary text-sm py-2 px-6">Launch Demo</button>
				</div>
			</div>
		</nav>

		<slot />

		<!-- Global Footer -->
		<footer class="py-24 px-10 border-t border-white/5 bg-nexus-slate-950">
			<div class="max-w-7xl mx-auto">
				<div class="grid grid-cols-1 md:grid-cols-4 gap-16 mb-20">
					<div class="col-span-1 md:col-span-1">
						<div class="flex items-center gap-3 mb-8">
							<div class="w-8 h-8 bg-nexus-blue-600 rounded-lg flex items-center justify-center text-white">
								<svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10"/></svg>
							</div>
							<span class="text-lg font-black italic uppercase">Nexus</span>
						</div>
						<p class="text-slate-500 font-medium leading-relaxed mb-8">
							The operating system for human potential. Unified enterprise intelligence for modern teams.
						</p>
					</div>
					
					<div>
						<h4 class="text-xs font-black uppercase tracking-[0.3em] text-nexus-blue-500 mb-8">Product</h4>
						<ul class="space-y-4">
							<li><a href="#" class="text-sm font-bold text-slate-400 hover:text-white transition-colors">Nuclear Payroll</a></li>
							<li><a href="#" class="text-sm font-bold text-slate-400 hover:text-white transition-colors">Cortex AI</a></li>
							<li><a href="#" class="text-sm font-bold text-slate-400 hover:text-white transition-colors">Biometric Presence</a></li>
						</ul>
					</div>

					<div>
						<h4 class="text-xs font-black uppercase tracking-[0.3em] text-nexus-blue-500 mb-8">Company</h4>
						<ul class="space-y-4">
							<li><a href="#" class="text-sm font-bold text-slate-400 hover:text-white transition-colors">Security Exhibit</a></li>
							<li><a href="#" class="text-sm font-bold text-slate-400 hover:text-white transition-colors">Ethics Policy</a></li>
							<li><a href="#" class="text-sm font-bold text-slate-400 hover:text-white transition-colors">Contact Support</a></li>
						</ul>
					</div>

					<div>
						<h4 class="text-xs font-black uppercase tracking-[0.3em] text-nexus-blue-500 mb-8">Newsletter</h4>
						<div class="flex gap-2">
							<input type="email" placeholder="Email" class="bg-white/5 border border-white/10 rounded-xl px-4 py-3 text-sm focus:outline-none focus:border-nexus-blue-600 transition-colors w-full" />
							<button class="bg-nexus-blue-600 p-3 rounded-xl hover:bg-nexus-blue-500 transition-colors">
								<svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><line x1="22" y1="2" x2="11" y2="13"/><polyline points="22 2 15 22 11 13 2 9 22 2"/></svg>
							</button>
						</div>
					</div>
				</div>
				
				<div class="flex flex-col md:flex-row justify-between items-center gap-8 border-t border-white/5 pt-12">
					<p class="text-[10px] font-bold text-slate-600 uppercase tracking-widest">© 2026 NEXUS CORE. ALL RIGHTS RESERVED.</p>
					<div class="flex gap-8">
						<a href="#" class="text-[10px] font-bold text-slate-500 hover:text-white uppercase tracking-widest">Privacy</a>
						<a href="#" class="text-[10px] font-bold text-slate-500 hover:text-white uppercase tracking-widest">Terms</a>
						<a href="#" class="text-[10px] font-bold text-slate-500 hover:text-white uppercase tracking-widest">Infrastructure</a>
					</div>
				</div>
			</div>
		</footer>
	</body>
</html>
