---
import '../styles/global.css';

interface Props {
	title: string;
	description?: string;
}

const { title, description = "Nexus HRM - The Operating System for Human Potential. Enterprise-grade HR management for modern teams." } = Astro.props;
---

<!doctype html>
<html lang="en">
	<head>
		<meta charset="UTF-8" />
		<meta name="description" content={description} />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<meta name="generator" content={Astro.generator} />
		<title>{title} | Nexus HRM Platform</title>
	</head>
	<body class="bg-[#0A0E1A] overflow-x-hidden selection:bg-nexus-amber selection:text-black">
		<!-- Global Navigation -->
		<nav class="fixed top-0 left-0 w-full z-50 px-6 py-6">
			<div class="max-w-7xl mx-auto flex items-center justify-between px-8 py-4 bg-[#111827]/80 backdrop-blur-xl border border-white/5 rounded-3xl shadow-2xl">
				<a href="/" class="flex items-center gap-3 group">
					<div class="w-10 h-10 bg-nexus-amber rounded-xl flex items-center justify-center text-black shadow-lg shadow-nexus-amber/20 group-hover:scale-110 transition-transform">
						<svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10"/></svg>
					</div>
					<span class="text-xl font-black italic tracking-tighter uppercase text-nexus-amber">Nexus</span>
				</a>

				<div class="hidden md:flex items-center gap-10">
					<a href="/features" class="text-xs font-black uppercase tracking-widest text-slate-400 hover:text-white transition-colors">Features</a>
					<a href="/compare" class="text-xs font-black uppercase tracking-widest text-slate-400 hover:text-white transition-colors">Compare</a>
					<a href="/pricing" class="text-xs font-black uppercase tracking-widest text-slate-400 hover:text-white transition-colors">Pricing</a>
					<a href="/demo" class="text-xs font-black uppercase tracking-widest text-slate-400 hover:text-white transition-colors">Demo</a>
					<a href="/contact" class="text-xs font-black uppercase tracking-widest text-slate-400 hover:text-white transition-colors">Contact</a>
				</div>

				<div class="flex items-center gap-6">
					<a href="https://nexus-hr-platform.web.app/login" class="hidden sm:block text-xs font-black uppercase tracking-widest text-white hover:text-nexus-amber transition-colors">Log In</a>
					<a href="/demo" class="px-8 py-3 bg-nexus-amber text-black rounded-xl font-black text-xs uppercase tracking-widest hover:scale-105 transition-all shadow-xl shadow-nexus-amber/5">Start Free Trial</a>
				</div>
			</div>
		</nav>

		<slot />

		<!-- Global Footer -->
		<footer class="py-32 px-10 border-t border-white/5 bg-[#0A0E1A]">
			<div class="max-w-7xl mx-auto">
				<div class="grid grid-cols-1 md:grid-cols-4 gap-20 mb-24">
					<div class="col-span-1 md:col-span-1">
						<div class="flex items-center gap-3 mb-8">
							<div class="w-8 h-8 bg-white rounded-lg flex items-center justify-center text-black">
								<svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10"/></svg>
							</div>
							<span class="text-lg font-black italic uppercase text-white">Nexus</span>
						</div>
						<p class="text-slate-500 font-medium leading-relaxed">
							The operating system for human potential. Africa's most aggressive AI-powered HRM platform.
						</p>
					</div>
					
					<div>
						<h4 class="text-[10px] font-black uppercase tracking-[0.4em] text-nexus-amber mb-10">Product Hub</h4>
						<ul class="space-y-5">
							<li><a href="/features" class="text-sm font-bold text-slate-500 hover:text-white transition-colors">Core Capabilities</a></li>
							<li><a href="/compare" class="text-sm font-bold text-slate-500 hover:text-white transition-colors">Strategic Comparison</a></li>
							<li><a href="/pricing" class="text-sm font-bold text-slate-500 hover:text-white transition-colors">Cedi-Based Pricing</a></li>
						</ul>
					</div>

					<div>
						<h4 class="text-[10px] font-black uppercase tracking-[0.4em] text-nexus-amber mb-10">Governance</h4>
						<ul class="space-y-5">
							<li><a href="#" class="text-sm font-bold text-slate-500 hover:text-white transition-colors">Security Exhibit</a></li>
							<li><a href="#" class="text-sm font-bold text-slate-500 hover:text-white transition-colors">Infrastructure</a></li>
							<li><a href="#" class="text-sm font-bold text-slate-500 hover:text-white transition-colors">Ethics & Privacy</a></li>
						</ul>
					</div>

					<div>
						<h4 class="text-[10px] font-black uppercase tracking-[0.4em] text-nexus-amber mb-10">Social Proof</h4>
						<div class="flex gap-6">
							{['LinkedIn', 'Twitter', 'GitHub'].map(item => (
								<a href="#" class="text-slate-500 hover:text-white transition-colors">
									<span class="text-xs font-black uppercase tracking-widest">{item}</span>
								</a>
							))}
						</div>
					</div>
				</div>
				
				<div class="flex flex-col md:flex-row justify-between items-center gap-8 border-t border-white/5 pt-12">
					<p class="text-[10px] font-black text-slate-600 uppercase tracking-[0.5em]">© 2026 STORMGLIDE ENTERPRISE SYSTEMS. ALL RIGHTS RESERVED.</p>
					<p class="text-[8px] font-black text-slate-700 uppercase tracking-widest">A Product of Stormglide Enterprise Systems & Logistics Solutions, Ghana.</p>
				</div>
			</div>
		</footer>

		<!-- WhatsApp Advisory Button -->
		<a href="https://wa.me/233XXXXXXXXX" class="fixed bottom-10 right-10 w-16 h-16 bg-[#25D366] rounded-full flex items-center justify-center text-white shadow-2xl shadow-emerald-500/20 hover:scale-110 transition-all z-[60] group">
			<svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" class="group-hover:rotate-12 transition-transform"><path d="M21 11.5a8.38 8.38 0 0 1-.9 3.8 8.5 8.5 0 0 1-7.6 4.7 8.38 8.38 0 0 1-3.8-.9L3 21l1.9-5.7a8.38 8.38 0 0 1-.9-3.8 8.5 8.5 0 0 1 4.7-7.6 8.38 8.38 0 0 1 3.8-.9h.5a8.48 8.48 0 0 1 8 8v.5z"/></svg>
		</a>
	</body>
</html>
